# Copy this file to .env and fill only the provider you use.
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=1
OPENAI_API_KEY=

# Other supported providers:
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# CUSTOM_BASE_URL=
# CUSTOM_API_KEY=
# OLLAMA_BASE_URL=http://localhost:11434

COMPACT_THRESHOLD_TOKENS=1200
COMPACT_KEEP_MESSAGES=6
